{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"lib": [
			"ES2020",
			"DOM",
			"DOM.Iterable"
		],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"isolatedModules": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["packages/*"]
		},
		"types": [
			"vitepress/client"
		],
	},
	"include": [
		"packages/**/*.ts",
		"packages/**/*.mts",
		"packages/**/*.d.ts",
		"packages/**/*.vue",
		"prettier.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
	]
}